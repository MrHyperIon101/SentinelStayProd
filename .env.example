VITE_SUPABASE_ANON_KEY=sb_publishable_qQg3RrbrreaUyieE_CXsEw_b9G8jKS1

# --- Server-side (required for `npm run simulate`) -----------------------
# Use the *service role* key here, not the anon key. Keep it secret.
SUPABASE_URL=https://trhvwiwugdohpbjnuxvu.supabase.co
SUPABASE_SERVICE_KEY=sb_publishable_qQg3RrbrreaUyieE_CXsEw_b9G8jKS1

